    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; scroll-behavior: smooth; }
    body {
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 14px;
      line-height: 1.6;
      min-height: 100vh;
    }
    a { color: var(--color-gold); text-decoration: none; }
    a:hover { color: var(--color-gold-light); }
    strong { color: var(--color-text); font-weight: 600; }
    .appShell { display: flex; flex-direction: column; min-height: 100vh; }
    .disclaimer {
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: 6px 24px;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--color-muted);
      text-align: center;
    }
    .alpha { color: var(--color-gold-dim); font-weight: 500; }
    header {
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: 0 24px;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .logo {
      font-family: var(--font-display);
      font-size: 16px;
      font-weight: 700;
      color: var(--color-gold);
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    nav { display: flex; align-items: center; gap: 8px; }
    .navLink { font-size: 12px; font-weight: 500; color: var(--color-text-soft); padding: 6px 10px; }
    .navLink:hover { color: var(--color-text); }
    .navBtn {
      font-size: 11px; font-weight: 600; color: var(--color-gold);
      border: 1px solid var(--color-gold); padding: 5px 14px;
      letter-spacing: 0.06em; text-transform: uppercase;
      font-family: var(--font-mono); background: transparent;
    }
    .navBtn:hover { background: rgba(200,155,60,0.1); }
    .appMain { flex: 1; }
    .page { max-width: 720px; margin: 0 auto; padding: 48px 24px 80px; }
    .label {
      font-family: var(--font-mono); font-size: 11px; font-weight: 500;
      color: var(--color-gold); text-transform: uppercase;
      letter-spacing: 0.12em; margin-bottom: 12px;
    }
    .title {
      font-family: var(--font-display);
      font-size: clamp(28px, 5vw, 44px);
      font-weight: 700; color: var(--color-text);
      line-height: 1.1; margin-bottom: 4px;
    }
    .subtitle {
      font-family: var(--font-mono); font-size: 13px;
      color: var(--color-muted); margin-bottom: 28px; letter-spacing: 0.04em;
    }
    .statement { border-left: 2px solid var(--color-gold-dim); padding-left: 20px; margin-bottom: 48px; }
    .body p { color: var(--color-text-soft); font-size: 14px; line-height: 1.75; margin-bottom: 16px; max-width: 66ch; }
    .body p:last-child { margin-bottom: 0; }
    .sign { font-family: var(--font-mono); font-size: 12px; color: var(--color-muted); margin-top: 24px !important; font-style: italic; }
    .statsLabel {
      font-family: var(--font-mono); font-size: 11px; color: var(--color-gold);
      text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 16px;
    }
    .statGrid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(160px, 100%), 1fr));
      gap: 1px; background: var(--color-border); border: 1px solid var(--color-border);
    }
    .stat { background: var(--color-surface); padding: 20px 16px; display: flex; flex-direction: column; gap: 4px; }
    .statValue { font-family: var(--font-mono); font-size: 22px; font-weight: 500; color: var(--color-gold); line-height: 1; }
    .statName { font-family: var(--font-mono); font-size: 10px; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.08em; }
    .miniStatRow {
