    .miniName { font-family: var(--font-mono); font-size: 10px; color: var(--color-muted); text-transform: uppercase; letter-spacing: 0.06em; }
    .chartLabel {
      font-family: var(--font-mono); font-size: 11px; color: var(--color-gold);
      text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 12px;
