    .axis-text { font-family: 'Fira Mono', monospace; font-size: 9px; fill: #5a5650; }
    .grid-line { stroke: #2a2730; stroke-dasharray: 3 3; }
    .hbar-fill { fill: #c89b3c; opacity: 0.8; }
    .hbar-label { font-family: 'Fira Mono', monospace; font-size: 10px; fill: #9e9a8e; }
    .chartRow { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
    .legend { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-top: 10px; }
    .legend-item { display: flex; align-items: center; gap: 5px; font-family: var(--font-mono); font-size: 10px; color: var(--color-text-soft); }
    footer { border-top: 1px solid var(--color-border); padding: 20px 24px; text-align: center; }
    .footer-text { font-family: var(--font-mono); font-size: 11px; color: var(--color-muted); }
    @media (max-width: 540px) {
